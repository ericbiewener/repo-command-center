{
  "name": "ai-work-command-center",
  "version": "1.0.0",
  "description": "macOS menu bar command center for AI-assisted coding workstreams.",
  "author": "Eric Biewener",
  "type": "module",
  "main": "out/main/main.js",
  "bin": {
    "agent-hook": "dist/cli/ai-work-status.js",
    "cli-command-center": "dist/cli/view.js"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "pnpm build:cli && electron-vite build",
    "bundle": "pnpm build && electron-builder --mac",
    "build:cli": "scripts/build-cli.sh",
    "build:cli:watch": "scripts/build-cli.sh --watch",
    "dev:cli": "npx tsx --watch src/cli/view.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "husky",
    "sessions": "pgrep -fl claude",
    "postinstall": "pnpm build:cli"
  },
  "build": {
    "appId": "com.ebiewener.ai-work-command-center",
    "productName": "AI Work Command Center",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": null
    }
  },
  "lint-staged": {
    "*.{css,json,md,ts,tsx}": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "fuzzysort": "^3.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@clack/prompts": "^1.5.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/yargs": "^17.0.35",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.15.3",
    "electron-vite": "^4.0.0",
    "execa": "^9.6.1",
    "fuzzy": "^0.1.3",
    "husky": "^9.1.7",
    "ink": "^7.0.6",
    "lint-staged": "^16.2.7",
    "lucide-react": "^0.555.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.15",
    "yargs": "^18.0.0",
    "zod": "^4.1.13"
  }
}
